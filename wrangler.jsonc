{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mindpang-issue",
  "main": "worker.ts",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "keep_names": false,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
